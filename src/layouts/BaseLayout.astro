---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import Nav from '@components/ui/Nav.astro';
import Footer from '@components/ui/Footer.astro';
import Loader from '@components/ui/Loader.astro';
import FloatingSignatureBadge from '@components/ui/FloatingSignatureBadge.astro';
import { defaultLocale, type Locale } from '@i18n/config';
import { getTranslation } from '@i18n/translations';
import { getAlternateUrls } from '@i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  keywords?: string[];
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const { 
  title, 
  description = "Portfolio d'Adonai Nangui - Senior Frontend Engineer & Tech Lead", 
  ogImage,
  locale = defaultLocale,
  keywords = [],
  ogType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://adonainangui.dev');
const alternateUrls = getAlternateUrls(Astro.url.pathname, Astro.site ? String(Astro.site) : undefined);
const htmlLang = locale === 'fr' ? 'fr' : 'en';
const ogLocale = locale === 'fr' ? 'fr_FR' : 'en_US';
const skipToContent = getTranslation('common', 'skipToContent', locale);
const siteUrl = String(Astro.site || 'https://adonainangui.dev').replace(/\/$/, '');

const baseKeywords = [
  'Adonai Nangui',
  'Senior Frontend Engineer',
  'Tech Lead',
  'Frontend Architecture',
  'React',
  'Vue.js',
  'Angular',
  'Next.js',
  'TypeScript',
  'Laravel',
  'NestJS',
  'Micro Frontend',
  'Module Federation',
  'Web Performance',
  'Web Accessibility',
  'NX Monorepo',
  'Portfolio',
];

const keywordsContent = Array.from(
  new Set([...baseKeywords, ...keywords].map((keyword) => keyword.trim()).filter(Boolean))
).join(', ');

const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http')
      ? ogImage
      : `${siteUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`)
  : `${siteUrl}/hero-image.jpeg`;

const getImageType = (url: string): string => {
  const lowered = url.toLowerCase();
  if (lowered.endsWith('.png')) return 'image/png';
  if (lowered.endsWith('.webp')) return 'image/webp';
  if (lowered.endsWith('.svg')) return 'image/svg+xml';
  return 'image/jpeg';
};

const ogImageType = getImageType(resolvedOgImage);
---

<!doctype html>
<html lang={htmlLang} class="no-js" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordsContent} />
    <meta name="author" content="Adonai Nangui" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0F1117" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Adonai Nangui - Portfolio" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:secure_url" content={resolvedOgImage} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {alternateUrls.map(({ lang, url }) => (
      <link rel="alternate" hreflang={lang} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/fr`} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:url" content={canonicalURL} />
    
    <!-- Schema.org Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Adonai Nangui",
      "jobTitle": "Senior Frontend Engineer / Tech Lead",
      "url": "https://adonainangui.dev",
      "sameAs": [
        "https://linkedin.com/in/adonai-nangui",
        "https://github.com/nangui"
      ],
      "knowsAbout": [
        "Frontend Development",
        "React",
        "Vue.js",
        "Angular",
        "Next.js",
        "NestJS",
        "TypeScript",
        "Micro Frontend Architecture",
        "NX",
        "Laravel",
        "Web Accessibility",
        "Web Performance",
        "PHP"
      ],
      "hasOccupation": [
        { "@type": "Occupation", "name": "Senior Frontend Engineer" },
        { "@type": "Occupation", "name": "Tech Lead" },
        { "@type": "Occupation", "name": "Full Stack Engineer" }
      ]
    })} />
    
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    
    <!-- Vercel Analytics -->
    <Analytics />
    
    <!-- Remove no-js class si JavaScript est activé -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      
      // Initialize theme before page renders to prevent flash
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        const theme = stored || (prefersLight ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    
  </head>
  <body>
    <Loader />
    <!-- Skip to main content link for keyboard navigation -->
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded focus:shadow-lg"
      aria-label={skipToContent}
    >
      {skipToContent}
    </a>
    <Nav locale={locale} />
    <main id="main-content" role="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <FloatingSignatureBadge />
    
    <!-- External links icons -->
    <script>
      const initExternalLinks = () => {
        import('@utils/externalLinks').then(({ addExternalLinkIcons }) => {
          addExternalLinkIcons();
        }).catch((err) => {
          console.error('Failed to load external links utility:', err);
        });
      };
      
      // Run on initial load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initExternalLinks);
      } else {
        initExternalLinks();
      }
    </script>

    <!-- Lightweight analytics events -->
    <script is:inline>
      (function() {
        const trackEvent = (eventName, data) => {
          if (!window.va || !eventName) return;
          window.va('event', { name: eventName, data: data || {} });
        };

        document.addEventListener('click', (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) return;

          const tracked = target.closest('[data-analytics-event]');
          if (tracked) {
            const eventName = tracked.getAttribute('data-analytics-event');
            const label = tracked.getAttribute('data-analytics-label') || tracked.textContent?.trim() || '';
            trackEvent(eventName, { label });
            return;
          }

          const link = target.closest('a[href]');
          if (!link) return;

          try {
            const destination = new URL(link.getAttribute('href'), window.location.origin);
            const isExternal = destination.origin !== window.location.origin;
            if (isExternal) {
              trackEvent('outbound_link_click', {
                href: destination.href,
                text: link.textContent?.trim() || '',
              });
            }
          } catch (_) {
            // ignore invalid URLs
          }
        }, { passive: true });
      })();
    </script>
  </body>
</html>
