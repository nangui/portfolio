---
import { defaultLocale, type Locale } from '@i18n/config';
import { getTranslation } from '@i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;

const domains = locale === 'fr'
  ? [
      {
        title: 'Frontend',
        summary: 'Applications web robustes, accessibles et rapides.',
        items: ['React / Next.js', 'Vue / Nuxt', 'Angular', 'TypeScript', 'Astro'],
      },
      {
        title: 'Architecture',
        summary: 'Systèmes évolutifs pour équipes produit multi-domaines.',
        items: ['NX Monorepo', 'Module Federation', 'Micro Frontend', 'Design Systems', 'SSR / SSG'],
      },
      {
        title: 'Backend',
        summary: 'APIs stables et orientees performance.',
        items: ['Laravel', 'Nest.js', 'PHP 8+', 'GraphQL', 'RESTful APIs'],
      },
      {
        title: 'Tooling',
        summary: 'Qualite, observabilite, livraison continue et copilotes IA.',
        items: ['Codex / Cursor / Claude Code / Warp', 'Docker', 'CI/CD', 'Redis', 'Tests E2E', 'Monitoring produit'],
      },
    ]
  : [
      {
        title: 'Frontend',
        summary: 'Reliable, accessible, and fast web interfaces.',
        items: ['React / Next.js', 'Vue / Nuxt', 'Angular', 'TypeScript', 'Astro'],
      },
      {
        title: 'Architecture',
        summary: 'Scalable systems for multi-domain product teams.',
        items: ['NX Monorepo', 'Module Federation', 'Micro Frontend', 'Design Systems', 'SSR / SSG'],
      },
      {
        title: 'Backend',
        summary: 'Stable API foundations built for performance.',
        items: ['Laravel', 'Nest.js', 'PHP 8+', 'GraphQL', 'RESTful APIs'],
      },
      {
        title: 'Tooling',
        summary: 'Quality, observability, delivery workflow, and AI copilots.',
        items: ['Codex / Cursor / Claude Code / Warp', 'Docker', 'CI/CD', 'Redis', 'E2E Testing', 'Product Monitoring'],
      },
    ];
---

<section id="skills" class="py-section bg-secondary" aria-labelledby="skills-heading">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
    <header class="mb-10 md:mb-12 max-w-3xl">
      <h2 id="skills-heading" class="font-heading font-semibold text-3xl md:text-4xl text-primary mb-3">
        {getTranslation('skills', 'heading', locale)}
      </h2>
      <p class="text-secondary text-sm sm:text-base">
        {locale === 'fr'
          ? "Stack orientee produit: architecture frontend, accessibilite web, performance et delivery."
          : "Product-oriented stack: frontend architecture, web accessibility, performance, and delivery."}
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      {
        domains.map((domain) => (
          <article class="skill-card rounded-xl border border-border-default bg-primary p-4 sm:p-5">
            <h3 class="font-heading text-lg text-primary mb-1">{domain.title}</h3>
            <p class="text-secondary text-sm mb-4">{domain.summary}</p>
            <ul class="space-y-2 text-sm text-secondary" role="list">
              {domain.items.map((item) => (
                <li class="skill-item">{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skill-card {
    min-height: 100%;
  }

  .skill-item {
    position: relative;
    padding-left: 0.9rem;
    line-height: 1.4;
  }

  .skill-item::before {
    content: '';
    position: absolute;
    top: 0.55em;
    left: 0;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  @media (max-width: 640px) {
    .skill-card {
      padding: 1rem;
    }
  }
</style>
