---
import { defaultLocale, type Locale } from '@i18n/config';
import { getTranslation } from '@i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const availabilityLabel =
  locale === 'fr' ? 'Disponible pour de nouvelles missions' : 'Available for new engagements';
const responsePromise =
  locale === 'fr' ? 'Réponse en moins de 24 heures ouvrées' : 'Response in less than 24 business hours';

const contactLinks = [
  { key: 'email', href: 'mailto:adonainangui03@gmail.com', icon: 'email' },
  { key: 'linkedin', href: 'https://linkedin.com/in/adonai-nangui', icon: 'linkedin' },
  { key: 'github', href: 'https://github.com/nangui', icon: 'github' },
];

const icons: Record<string, string> = {
  email: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
  </svg>`,
  linkedin: `<svg class="w-6 h-6" viewBox="0 0 20 20" aria-hidden="true"><path fill="currentColor" d="M5 3c0 1.062-.71 1.976-2.001 1.976C1.784 4.976 1 4.114 1 3.052C1 1.962 1.76 1 3 1s1.976.91 2 2M1 19V6h4v13zm6-8.556c0-1.545-.051-2.836-.102-3.951h3.594l.178 1.723h.076c.506-.811 1.746-2 3.822-2C17.1 6.216 19 7.911 19 11.558V19h-4v-6.861c0-1.594-.607-2.81-2-2.81c-1.062 0-1.594.86-1.873 1.569c-.102.254-.127.608-.127.963V19H7z"/></svg>`,
  github: `<svg class="w-6 h-6" viewBox="0 0 20 20" aria-hidden="true"><path fill="currentColor" d="M13.18 11.309c-.718 0-1.3.807-1.3 1.799c0 .994.582 1.801 1.3 1.801s1.3-.807 1.3-1.801c-.001-.992-.582-1.799-1.3-1.799m4.526-4.683c.149-.365.155-2.439-.635-4.426c0 0-1.811.199-4.551 2.08c-.575-.16-1.548-.238-2.519-.238c-.973 0-1.945.078-2.52.238C4.74 2.399 2.929 2.2 2.929 2.2c-.789 1.987-.781 4.061-.634 4.426C1.367 7.634.8 8.845.8 10.497c0 7.186 5.963 7.301 7.467 7.301l1.734.002l1.732-.002c1.506 0 7.467-.115 7.467-7.301c0-1.652-.566-2.863-1.494-3.871m-7.678 10.289h-.056c-3.771 0-6.709-.449-6.709-4.115c0-.879.31-1.693 1.047-2.369C5.537 9.304 7.615 9.9 9.972 9.9h.056c2.357 0 4.436-.596 5.664.531c.735.676 1.045 1.49 1.045 2.369c0 3.666-2.937 4.115-6.709 4.115m-3.207-5.606c-.718 0-1.3.807-1.3 1.799c0 .994.582 1.801 1.3 1.801s1.301-.807 1.301-1.801c0-.992-.582-1.799-1.301-1.799"/></svg>`,
};
---

<section id="contact" class="py-section bg-primary" aria-labelledby="contact-heading">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="contact-shell rounded-2xl border border-border-default p-6 md:p-8 lg:p-10">
      <header class="mb-7 md:mb-8 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <div class="max-w-3xl">
          <h2 id="contact-heading" class="font-heading font-semibold text-3xl md:text-4xl text-primary mb-3">
            {getTranslation('contact', 'heading', locale)}
          </h2>
          <p class="text-secondary text-base md:text-lg">
            {getTranslation('contact', 'description', locale)}
          </p>
        </div>
        <p class="contact-status rounded-full border border-border-default px-4 py-2 text-xs font-medium text-secondary w-fit">
          {availabilityLabel}
        </p>
      </header>

      <ul class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-5" role="list">
        {contactLinks.map((link) => {
          const label = getTranslation('contact', `${link.key}Label`, locale);
          const description = getTranslation('contact', `${link.key}Description`, locale);
          return (
            <li>
              <a
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="contact-card group rounded-xl border border-border-default p-5 md:p-6 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent hover:border-accent"
                aria-label={`${label} - ${description}`}
                data-analytics-event="contact_click"
                data-analytics-label={link.key}
              >
                <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg border border-border-default bg-bg-secondary text-accent">
                  <span set:html={icons[link.icon]} />
                </div>

                <h3 class="font-heading font-semibold text-xl text-primary mb-1.5 group-hover:text-accent">
                  {label}
                </h3>

                <p class="text-sm text-secondary mb-5 leading-relaxed">
                  {description}
                </p>

                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-secondary group-hover:text-primary">
                  {locale === 'fr' ? 'Ouvrir' : 'Open'}
                  <span aria-hidden="true">↗</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>

      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-3">
        <p class="contact-meta rounded-xl border border-border-default px-4 py-3 text-sm text-secondary">
          {getTranslation('contact', 'location', locale)}
        </p>
        <p class="contact-meta rounded-xl border border-border-default px-4 py-3 text-sm text-secondary">
          {responsePromise}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-shell {
    background-color: var(--color-bg-primary);
  }

  .contact-card {
    display: block;
    min-height: 100%;
    background-color: var(--color-bg-secondary);
  }

  .contact-status {
    background-color: color-mix(in srgb, var(--color-bg-secondary) 78%, transparent);
  }

  .contact-meta {
    background-color: color-mix(in srgb, var(--color-bg-secondary) 82%, transparent);
  }
</style>
