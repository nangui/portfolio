---
import { defaultLocale, type Locale } from '@i18n/config';
import { getTranslation } from '@i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;

const experiences = [
  { key: 'masskode', company: 'MassKode', impactCount: 5 },
  { key: 'djoubo', company: 'Djoubo', impactCount: 5 },
  { key: 'gebeya-senior', company: 'Gebeya Inc', impactCount: 4 },
  { key: 'socium', company: 'Socium', impactCount: 4 },
  { key: 'sonatel', company: 'Sonatel', impactCount: 4 },
  { key: 'gebeya-fullstack', company: 'Gebeya Inc', impactCount: 4 },
];

const getExperienceData = (exp: (typeof experiences)[0], currentLocale: Locale) => {
  const role = getTranslation('experience', `${exp.key}.role`, currentLocale);
  const period = getTranslation('experience', `${exp.key}.period`, currentLocale);
  const impacts: string[] = [];

  for (let i = 1; i <= exp.impactCount; i += 1) {
    const impact = getTranslation('experience', `${exp.key}.impact${i}`, currentLocale);
    if (impact && impact !== `${exp.key}.impact${i}`) impacts.push(impact);
  }

  return { role, period, company: exp.company, impacts };
};

const expertiseKeywords = locale === 'fr'
  ? [
      'Senior Frontend Engineer',
      'Tech Lead',
      'React',
      'Vue.js',
      'Angular',
      'Next.js',
      'TypeScript',
      'NestJS',
      'Laravel',
      'Micro-Frontend',
      'Module Federation',
      'Accessibilité Web',
      'Performance Web',
      'Architecture logicielle',
    ]
  : [
      'Senior Frontend Engineer',
      'Tech Lead',
      'React',
      'Vue.js',
      'Angular',
      'Next.js',
      'TypeScript',
      'NestJS',
      'Laravel',
      'Micro Frontend',
      'Module Federation',
      'Web Accessibility',
      'Web Performance',
      'Software Architecture',
    ];
---

<section id="experience" class="py-section bg-secondary" aria-labelledby="experience-heading">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="experience-heading" class="font-heading font-semibold text-3xl md:text-4xl text-primary mb-10 md:mb-12">
      {getTranslation('experience', 'heading', locale)}
    </h2>

    <ul class="flex flex-wrap gap-2 mb-8 md:mb-10" aria-label={locale === 'fr' ? 'Mots-clés expérience' : 'Experience keywords'}>
      {expertiseKeywords.map((keyword) => (
        <li class="rounded-full border border-border-default bg-bg-secondary px-3 py-1.5 text-xs md:text-sm text-secondary">
          {keyword}
        </li>
      ))}
    </ul>

    <ol class="relative space-y-6 border-l border-border-default pl-5 md:pl-7">
      {experiences.map((exp, index) => {
        const expData = getExperienceData(exp, locale);
        return (
          <li class="relative">
            <span
              class="absolute -left-[30px] md:-left-[38px] top-6 flex h-6 w-6 items-center justify-center rounded-full border border-border-default bg-bg-tertiary text-xs font-semibold text-secondary"
              aria-hidden="true"
            >
              {index + 1}
            </span>

            <article class="rounded-xl border border-border-default bg-bg-secondary p-5 md:p-6">
              <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
                <h3 class="font-heading text-lg md:text-xl font-semibold text-primary">
                  {expData.role}
                </h3>
                <p class="rounded-full border border-border-default px-3 py-1 text-xs text-secondary">
                  {expData.period}
                </p>
              </div>

              <p class="mb-4 text-sm font-medium text-secondary">{expData.company}</p>

              <ul class="space-y-2.5">
                {expData.impacts.map((impact) => (
                  <li class="flex items-start gap-2.5 text-sm text-secondary leading-relaxed">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent shrink-0" aria-hidden="true"></span>
                    <span>{impact}</span>
                  </li>
                ))}
              </ul>
            </article>
          </li>
        );
      })}
    </ol>
  </div>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Adonai Nangui',
      hasOccupation: experiences.map((exp) => ({
        '@type': 'Occupation',
        name: getTranslation('experience', `${exp.key}.role`, locale),
        occupationalCategory: 'Software Engineering',
      })),
      knowsAbout: expertiseKeywords,
    })}
  />
</section>
