---
const imageUrl = '/hero-image.jpeg';
---

<figure class="hero-image-shell" aria-label="Portrait d'Adonai Nangui">
  <img
    src={imageUrl}
    alt="Portrait d'Adonai Nangui"
    width="540"
    height="540"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    class="hero-image"
  />
</figure>

<style>
  .hero-image-shell {
    position: relative;
    width: clamp(136px, 32vw, 360px);
    aspect-ratio: 1;
    margin: 0;
    border-radius: 42% 58% 52% 48% / 46% 45% 55% 54%;
    background: #facc15;
    padding: 9px;
    box-shadow: 0 14px 34px rgba(2, 8, 22, 0.35);
    flex: 0 0 auto;
    opacity: 0.98;
    animation: heroImageShellOpacity 6.5s ease-in-out infinite;
  }

  .hero-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 46% 54% 48% 52% / 49% 46% 54% 51%;
    border: 2px solid color-mix(in srgb, var(--color-bg-primary) 75%, transparent);
    filter: grayscale(1) contrast(1.03);
    background: var(--color-bg-secondary);
    opacity: 0.96;
    animation: heroImageOpacity 6.5s ease-in-out infinite;
  }

  @keyframes heroImageShellOpacity {
    0%,
    100% {
      opacity: 0.98;
    }
    35% {
      opacity: 0.8;
    }
    62% {
      opacity: 0.9;
    }
  }

  @keyframes heroImageOpacity {
    0%,
    100% {
      opacity: 0.96;
    }
    35% {
      opacity: 0.72;
    }
    62% {
      opacity: 0.88;
    }
  }

  @media (max-width: 767px) {
    .hero-image-shell {
      width: clamp(124px, 33vw, 220px);
      padding: 7px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image-shell {
      animation: none;
      opacity: 1;
    }

    .hero-image {
      animation: none;
      opacity: 1;
    }
  }
</style>
