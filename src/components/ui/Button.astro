---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
  ariaLabel?: string;
  analyticsEvent?: string;
  analyticsLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  target,
  rel,
  ariaLabel,
  analyticsEvent,
  analyticsLabel,
} = Astro.props;

const baseClasses =
  'inline-flex items-center justify-center rounded-lg font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent';
const variantClasses = {
  primary: 'bg-accent text-white hover:bg-accent-hover',
  secondary: 'bg-secondary text-primary border border-border-default hover:border-border-light hover:bg-bg-secondary',
  ghost: 'text-secondary hover:text-primary hover:bg-secondary',
};
const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-5 py-2.5 text-sm md:text-base',
  lg: 'px-7 py-3 text-base md:text-lg',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={classes}
    target={target}
    rel={rel}
    {...(ariaLabel && { 'aria-label': ariaLabel })}
    {...(analyticsEvent && { 'data-analytics-event': analyticsEvent })}
    {...(analyticsLabel && { 'data-analytics-label': analyticsLabel })}
  >
    <slot />
  </a>
) : (
  <button
    class={classes}
    {...(ariaLabel && { 'aria-label': ariaLabel })}
    {...(analyticsEvent && { 'data-analytics-event': analyticsEvent })}
    {...(analyticsLabel && { 'data-analytics-label': analyticsLabel })}
  >
    <slot />
  </button>
)}
