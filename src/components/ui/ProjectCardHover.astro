---
---

<svg class="project-hover-svg" aria-hidden="true">
  <defs>
    <filter id="project-hover-distortion" x="-15%" y="-15%" width="130%" height="130%">
      <feTurbulence
        id="project-hover-turbulence"
        type="fractalNoise"
        baseFrequency="0.006 0.014"
        numOctaves="2"
        seed="2"
        result="noise"
      />
      <feDisplacementMap
        id="project-hover-displacement"
        in="SourceGraphic"
        in2="noise"
        scale="0"
        xChannelSelector="R"
        yChannelSelector="G"
      />
    </filter>
  </defs>
</svg>

<div id="project-hover-preview" class="project-hover-preview" aria-hidden="true">
  <img
    id="project-hover-image"
    class="project-hover-image"
    alt=""
    decoding="async"
    fetchpriority="low"
    draggable="false"
  />
</div>

<script>
  let destroyHover: (() => void) | null = null;

  const initProjectHover = () => {
    destroyHover?.();

    const supportsHover =
      window.matchMedia('(hover: hover)').matches &&
      window.matchMedia('(pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
      window.innerWidth >= 1024;
    if (!supportsHover) return;

    const preview = document.getElementById('project-hover-preview') as HTMLElement | null;
    const image = document.getElementById('project-hover-image') as HTMLImageElement | null;
    const displacement = document.getElementById('project-hover-displacement');
    const turbulence = document.getElementById('project-hover-turbulence');
    if (!preview || !image || !displacement || !turbulence) return;

    const cards = document.querySelectorAll<HTMLElement>('[data-project-image]');
    if (cards.length === 0) return;

    const controller = new AbortController();
    const signal = controller.signal;
    const preloadCache = new Set<string>();

    const preload = (src: string | null) => {
      if (!src || preloadCache.has(src)) return;
      const preloadImage = new Image();
      preloadImage.decoding = 'async';
      preloadImage.src = src;
      preloadCache.add(src);
    };

    cards.forEach((card) => preload(card.dataset.projectImage || null));

    let raf = 0;
    let isVisible = false;
    let currentSrc = '';
    let mouseX = 0;
    let mouseY = 0;
    let targetX = 0;
    let targetY = 0;
    let x = 0;
    let y = 0;
    let velocity = 0;
    const width = 320;
    const height = 220;

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

    const show = (src: string, title?: string) => {
      if (!src) return;
      if (currentSrc !== src) {
        image.src = src;
        image.alt = title || '';
        currentSrc = src;
      }

      isVisible = true;
      preview.classList.add('is-visible');
      preview.style.width = `${width}px`;
      preview.style.height = `${height}px`;
    };

    const hide = () => {
      isVisible = false;
      preview.classList.remove('is-visible');
      displacement.setAttribute('scale', '0');
      turbulence.setAttribute('baseFrequency', '0.006 0.014');
    };

    const animate = () => {
      raf = requestAnimationFrame(animate);

      if (!isVisible) return;

      const dx = targetX - x;
      const dy = targetY - y;
      x += dx * 0.14;
      y += dy * 0.14;
      velocity = clamp(Math.hypot(dx, dy), 0, 80);

      const distortion = clamp((velocity / 80) * 30, 0, 30);
      const turbulenceX = (0.006 + distortion * 0.00016).toFixed(4);
      const turbulenceY = (0.014 + distortion * 0.00025).toFixed(4);

      preview.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      displacement.setAttribute('scale', distortion.toFixed(2));
      turbulence.setAttribute('baseFrequency', `${turbulenceX} ${turbulenceY}`);
    };

    const onPointerMove = (event: PointerEvent) => {
      targetX = event.clientX - width * 0.5;
      targetY = event.clientY - height * 0.56;
      mouseX = event.clientX;
      mouseY = event.clientY;
      if (!isVisible) {
        x = targetX;
        y = targetY;
      }
    };

    cards.forEach((card) => {
      card.addEventListener(
        'pointerenter',
        (event) => {
          onPointerMove(event as PointerEvent);
          show(card.dataset.projectImage || '', card.dataset.projectTitle || '');
        },
        { signal }
      );

      card.addEventListener(
        'pointermove',
        (event) => {
          onPointerMove(event as PointerEvent);
        },
        { signal, passive: true }
      );

      card.addEventListener(
        'pointerleave',
        () => {
          hide();
        },
        { signal }
      );
    });

    window.addEventListener(
      'scroll',
      () => {
        if (isVisible) {
          targetX = mouseX - width * 0.5;
          targetY = mouseY - height * 0.56;
        }
      },
      { signal, passive: true }
    );

    animate();

    destroyHover = () => {
      controller.abort();
      if (raf) cancelAnimationFrame(raf);
      hide();
    };
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProjectHover, { once: true });
  } else {
    initProjectHover();
  }

  document.addEventListener('astro:page-load', initProjectHover);
</script>

<style>
  .project-hover-svg {
    position: absolute;
    width: 0;
    height: 0;
  }

  .project-hover-preview {
    position: fixed;
    left: 0;
    top: 0;
    z-index: 40;
    pointer-events: none;
    opacity: 0;
    transform: translate3d(-9999px, -9999px, 0);
    border-radius: 0.9rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border-light) 75%, transparent);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.28);
    background: var(--color-bg-secondary);
    transition: opacity 180ms ease;
    will-change: transform, opacity;
  }

  .project-hover-preview.is-visible {
    opacity: 1;
  }

  .project-hover-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: url(#project-hover-distortion);
  }

  @media (max-width: 1024px), (prefers-reduced-motion: reduce) {
    .project-hover-preview {
      display: none;
    }
  }
</style>
