---
---

<div class="site-loader" data-site-loader>
  <div class="loader-card" role="status" aria-live="polite" aria-atomic="true">
    <div class="loader-orbit" aria-hidden="true">
      <span class="loader-dot dot-a"></span>
      <span class="loader-dot dot-b"></span>
      <span class="loader-dot dot-c"></span>
    </div>
    <p class="loader-title">Adonai Nangui</p>
    <p class="loader-subtitle" data-loader-copy>Preparing a clean, accessible experience</p>
    <p class="loader-progress" data-loader-progress>0%</p>
  </div>
</div>

<style>
  .site-loader {
    position: fixed;
    inset: 0;
    z-index: 700;
    display: grid;
    place-items: center;
    background: var(--color-bg-primary);
  }

  .loader-card {
    width: min(320px, 88vw);
    border: 1px solid var(--color-border-default);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-bg-secondary) 92%, transparent);
    padding: 1.25rem 1rem;
    text-align: center;
    box-shadow: 0 22px 44px rgba(0, 0, 0, 0.22);
  }

  .loader-orbit {
    width: 70px;
    height: 70px;
    margin: 0 auto 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-border-light) 70%, transparent);
    position: relative;
    animation: loader-spin 2.4s linear infinite;
  }

  .loader-dot {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .dot-a {
    background: #3b82f6;
    transform: translate(-50%, -50%) translateX(30px);
  }

  .dot-b {
    background: #10b981;
    transform: translate(-50%, -50%) translateY(30px);
  }

  .dot-c {
    background: #f59e0b;
    transform: translate(-50%, -50%) translateX(-30px);
  }

  .loader-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
  }

  .loader-subtitle {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .loader-progress {
    margin: 0.7rem 0 0;
    font-size: 0.85rem;
    color: var(--color-accent-light);
    font-variant-numeric: tabular-nums;
  }

  .site-loader.is-exit {
    opacity: 0;
    visibility: hidden;
    transition: opacity 240ms ease, visibility 240ms ease;
  }

  @keyframes loader-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loader-orbit {
      animation: none;
    }

    .site-loader.is-exit {
      transition: none;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'portfolio-loader-v3';

  const initLoader = () => {
    const loader = document.querySelector('[data-site-loader]') as HTMLElement | null;
    const progress = document.querySelector('[data-loader-progress]') as HTMLElement | null;
    const copy = document.querySelector('[data-loader-copy]') as HTMLElement | null;
    if (!loader) return;

    const language = document.documentElement.lang === 'fr' ? 'fr' : 'en';
    if (copy) {
      copy.textContent =
        language === 'fr'
          ? 'Préparation d’une expérience rapide et accessible'
          : 'Preparing a fast, accessible experience';
    }

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hasSeenLoader = localStorage.getItem(STORAGE_KEY) === 'true';

    const finish = () => {
      loader.classList.add('is-exit');
      document.documentElement.classList.remove('is-loading');
      window.setTimeout(() => {
        loader.remove();
      }, 260);
      localStorage.setItem(STORAGE_KEY, 'true');
    };

    if (reduceMotion) {
      finish();
      return;
    }

    document.documentElement.classList.add('is-loading');
    const duration = hasSeenLoader ? 1700 : 2600;
    const start = performance.now();

    const tick = (now: number) => {
      const elapsed = now - start;
      const ratio = Math.min(elapsed / duration, 1);
      const percent = Math.round(ratio * 100);
      if (progress) {
        progress.textContent = `${percent}%`;
      }
      if (ratio < 1) {
        requestAnimationFrame(tick);
      } else {
        finish();
      }
    };

    requestAnimationFrame(tick);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLoader, { once: true });
  } else {
    initLoader();
  }
</script>
